{%- liquid
  assign collection_image = collection.image
  assign collection_title = collection.title
  assign collection_description = collection.description
  assign instagram_handle = section.settings.instagram_handle
  assign instagram_url = 'https://instagram.com/' | append: instagram_handle | remove: '@'
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    influencer-header
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    spacing-style
  "
  style="{%- render 'spacing-style', settings: section.settings -%}"
>
  <div class="influencer-header__inner">

    {%- if collection_image != blank -%}
      <div class="influencer-header__avatar">
        {{
          collection_image
          | image_url: width: 300
          | image_tag:
            width: 150,
            height: 150,
            alt: collection_title,
            class: 'influencer-header__avatar-img',
            loading: 'eager'
        }}
      </div>
    {%- endif -%}

    <div class="influencer-header__content">

      <h1 class="influencer-header__title">{{ collection_title }}</h1>

      {%- if collection_description != blank -%}
        <div class="influencer-header__bio">{{ collection_description }}</div>
      {%- endif -%}

      {%- if instagram_handle != blank -%}
        <a
          href="{{ instagram_url }}"
          class="influencer-header__instagram"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram profile: {{ instagram_handle }}"
        >
          <svg
            class="influencer-header__instagram-icon"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="17.5" cy="6.5" r="0.75" fill="currentColor"/>
          </svg>
          <span>{{ instagram_handle }}</span>
        </a>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
  .influencer-header__inner {
    display: flex;
    align-items: center;
    gap: 48px;
  }

  .influencer-header__avatar {
    flex-shrink: 0;
  }

  .influencer-header__avatar-img {
    width: 150px;
    height: 150px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }

  .influencer-header__content {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 560px;
  }

  .influencer-header__title {
    margin: 0;
    font-family: var(--font-primary--family);
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-foreground-heading);
  }

  .influencer-header__bio {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-foreground);
    margin: 0;
  }

  .influencer-header__bio p {
    margin: 0;
  }

  .influencer-header__instagram {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.9375rem;
    transition: opacity 0.2s ease;
    width: fit-content;
  }

  .influencer-header__instagram:hover {
    opacity: 0.6;
  }

  .influencer-header__instagram-icon {
    flex-shrink: 0;
    margin-top: 1px;
  }

  @media screen and (max-width: 749px) {
    .influencer-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .influencer-header__avatar-img {
      width: 100px;
      height: 100px;
    }

    .influencer-header__title {
      font-size: 1.75rem;
    }
  }
</style>

{% schema %}
{
  "name": "Influencer Header",
  "tag": "section",
  "class": "influencer-header-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Title, photo and bio are pulled automatically from the collection. Set the Instagram handle below."
    },
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "Instagram Handle",
      "placeholder": "@carmenboucher"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Influencer Header",
      "settings": {
        "section_width": "page-width",
        "color_scheme": "scheme-2",
        "padding-block-start": 48,
        "padding-block-end": 48
      }
    }
  ]
}
{% endschema %}
